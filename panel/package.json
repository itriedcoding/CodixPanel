{
  "name": "codix-panel",
  "version": "1.0.0",
  "private": true,
  "description": "Codix Panel - Open-source game server management",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
